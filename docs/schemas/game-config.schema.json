{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/GameConfigSchema",
  "definitions": {
    "GameConfigSchema": {
      "$ref": "#/definitions/GameConfig"
    },
    "GameConfig": {
      "type": "object",
      "properties": {
        "broadcastChannel": {
          "type": "string"
        },
        "app": {
          "$ref": "#/definitions/AppConfig"
        },
        "systems": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/JsonObject"
          }
        },
        "systemsOrder": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input": {
          "$ref": "#/definitions/InputConfig"
        },
        "layers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/LayerConfig"
          }
        },
        "objectTypes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ObjectTypeConfig"
          }
        },
        "assets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AssetConfig"
          }
        },
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EntityConfig"
          }
        }
      }
    },
    "AppConfig": {
      "type": "object",
      "properties": {
        "fullscreen": {
          "type": "boolean"
        },
        "width": {
          "type": [
            "number",
            "string"
          ]
        },
        "height": {
          "type": [
            "number",
            "string"
          ]
        },
        "background": {
          "type": "string"
        }
      }
    },
    "JsonObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/JsonValue"
      }
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/definitions/JsonPrimitive"
        },
        {
          "$ref": "#/definitions/JsonObject"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/JsonValue"
          }
        }
      ]
    },
    "JsonPrimitive": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "InputConfig": {
      "type": "object",
      "properties": {
        "actions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/JsonValue"
          }
        },
        "wheel": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        },
        "gamepad": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "LayerConfig": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "zIndex": {
          "type": "number"
        }
      },
      "required": [
        "name"
      ]
    },
    "ObjectTypeConfig": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "plugin": {
          "type": "string"
        },
        "layer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "zIndex": {
                  "type": "number"
                }
              }
            }
          ]
        },
        "transform": {
          "$ref": "#/definitions/TransformConfig"
        },
        "collision": {
          "$ref": "#/definitions/CollisionConfig"
        },
        "behaviors": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/BehaviorConfig"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instanceVariables": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/JsonValue"
          }
        }
      },
      "required": [
        "id"
      ]
    },
    "TransformConfig": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "rotation": {
          "type": "number"
        },
        "scaleX": {
          "type": "number"
        },
        "scaleY": {
          "type": "number"
        }
      }
    },
    "CollisionConfig": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "offsetX": {
          "type": "number"
        },
        "offsetY": {
          "type": "number"
        }
      }
    },
    "BehaviorConfig": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "type"
      ]
    },
    "AssetConfig": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "url"
      ]
    },
    "EntityConfig": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "uid": {
          "type": "number"
        },
        "type": {
          "type": "string"
        },
        "plugin": {
          "type": "string"
        },
        "layer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "zIndex": {
                  "type": "number"
                }
              }
            }
          ]
        },
        "transform": {
          "$ref": "#/definitions/TransformConfig"
        },
        "collision": {
          "$ref": "#/definitions/CollisionConfig"
        },
        "behaviors": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/BehaviorConfig"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instanceVariables": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/JsonValue"
          }
        }
      }
    }
  }
}
